# PRIA — Local Development Secrets
# Copy this to .streamlit/secrets.toml for local development
# ============================================================

# Google Gemini API (required for AI generation)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEYS=["YOUR_GEMINI_API_KEY"]

# Optional: Anthropic Claude API for premium slide generation
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Image generation API
IMAGE_API_KEY=

# Optional: App password for admin access
APP_PASSWORD=

# Optional: Railway PostgreSQL URL (leave empty for local SQLite)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
