{
  "name": "react_frontend",
  "private": true,
  "version": "10.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "cd server && npm install",
    "dev": "vite",
    "dev:clean": "taskkill /F /IM node.exe /T 2>nul; Start-Sleep 1; vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit --project tsconfig.app.json",
    "typecheck:strict": "tsc -b",
    "start": "NODE_ENV=production tsx server.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "smoke": "node scripts/smoke-test.js"
  },
  "dependencies": {
    "@sentry/node": "^10.54.0",
    "@sentry/react": "^10.56.0",
    "@tanstack/query-devtools": "^5.100.14",
    "@tanstack/react-query": "^5.100.14",
    "axios": "^1.18.1",
    "buffer": "^6.0.3",
    "docx": "^9.7.1",
    "express": "^4.21.0",
    "helmet": "^8.2.0",
    "html2canvas": "^1.4.1",
    "http-proxy-middleware": "^3.0.7",
    "jspdf": "^4.2.1",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.7.284",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0",
    "tesseract.js": "^7.0.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.3.6",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  }
}
