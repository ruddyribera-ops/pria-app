    "/api/motores/history": {
      "get": {
        "tags": ["motores"],
        "summary": "Get Motor History",
        "description": "Get paginated history of motor generation results.",
        "operationId": "get_motor_history_api_motores_history_get",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 1, "title": "Page" }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 20, "title": "Limit" }
          },
          {
            "name": "motor_type",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "title": "Motor Type Filter" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
