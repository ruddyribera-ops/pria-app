# PRIA — Railway Environment Variables
# Add these in Railway Dashboard → Variables tab
# ============================================================

# ── Google Gemini API (Primary AI Engine) ──────────────────
# Comma-separated or JSON array: ["key1","key2"] for key rotation
GEMINI_API_KEYS=["YOUR_GEMINI_API_KEY_HERE"]
GEMINI_MODEL=gemini-2.0-flash-lite

# ── Anthropic Claude API (Premium Slides Engine) ───────────
# Optional — falls back to python-pptx if not set
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────────────
# Railway PostgreSQL: copy from Railway dashboard → Variables
# Leave empty for local SQLite development
DATABASE_URL=

# ── Streamlit Server ──────────────────────────────────────
PORT=8080

# ── Image Generation (Optional) ────────────────────────────
IMAGE_API_KEY=

# ── Sentry Error Monitoring (Optional) ────────────────────
# Get DSN from sentry.io → Settings → Projects → Client Keys
# Leave empty to disable error reporting
SENTRY_DSN=
