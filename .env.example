# ============================================
# PRIA v7 Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your values

# ============================================
# Backend Configuration
# ============================================

# Database connection
# For development: sqlite:///./test.db
# For production: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://pria:pria@localhost:5432/pria_v7

# JWT Authentication
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_MODEL=gemini-2.0-flash

# Redis cache
REDIS_URL=redis://localhost:6379/0

# CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================
# Frontend Configuration
# ============================================

# API endpoint
NEXT_PUBLIC_API_URL=http://localhost:8000

# Application metadata
NEXT_PUBLIC_APP_NAME=PRIA v7
NEXT_PUBLIC_SCHOOL_NAME=Las Palmas

# ============================================
# Docker Configuration (for docker-compose.prod.yml)
# ============================================

# Database credentials
DB_USER=pria
DB_PASSWORD=pria_prod_secure_pw
DB_NAME=pria_v7

# Application secrets
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY_PROD=your-production-secret-key-32-chars-minimum

# ============================================
# Optional: Email Configuration (for future use)
# ============================================

# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# ============================================
# Optional: S3/Cloud Storage (for exports)
# ============================================

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET_NAME=pria-v7-exports
# AWS_REGION=us-east-1
