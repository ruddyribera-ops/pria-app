# -- Required --
JWT_SECRET=                           # openssl rand -hex 32
JWT_EXPIRY=24h

# -- Server --
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# -- Database --
DATABASE_URL=postgresql://postgres:pria_local@localhost:5432/pria

# -- MiniMax --
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_TEMPERATURE=0.2
MINIMAX_MAX_TOKENS=4096

# VITE_MINIMAX_API_KEY is NOT used -- the frontend proxies through the backend.
# The server uses MINIMAX_API_KEY (set in server/.env, NOT committed).
# -- Optional --
SENTRY_DSN=
ANALYTICS_ID=
