# === PRIA v10 Environment Variables ===

# --- Core (REQUIRED) ---
NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://user:pass@host:5432/dbname  # Railway auto-provides via DATABASE_URL
JWT_SECRET=                                        # Generate: openssl rand -hex 32

# --- AI / Motor (REQUIRED) ---
MINIMAX_API_KEY=                                   # Get from MiniMax dashboard
MINIMAX_BASE_URL=https://api.minimax.io/v1

# --- Frontend / Public URL (REQUIRED) ---
FRONTEND_URL=https://your-app.railway.app           # Used in password reset emails
VITE_API_URL=https://your-app.railway.app           # Frontend -> backend URL

# --- Email / SMTP (OPTIONAL but recommended for password reset) ---
SMTP_URL=smtp://user:pass@smtp.example.com:587     # Leave blank to log reset links to console (dev only)
FROM_EMAIL=noreply@your-domain.com                  # Default: noreply@pria.app

# --- Observability (OPTIONAL) ---
VITE_SENTRY_DSN=                                    # Get from sentry.io (free tier)
VITE_APP_VERSION=10.0.0
SENTRY_SERVER_DSN=                                  # Optional: server-side Sentry

# --- Operational (OPTIONAL) ---
RUN_SEED=false                                      # Set to "true" to force seed in production (DANGEROUS)
SKIP_INTEGRATION_TESTS=true                         # CI flag